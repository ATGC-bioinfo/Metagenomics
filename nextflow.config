// ── Metagenome Pipeline Configuration ────────────────────────────────────────

conda {
    enabled = true
    path = '/home/habee/miniconda3/bin/conda'
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
        process.time     = '72h'
        process.memory   = '32GB'
        process.cpus     = 8
    }

    cluster {
        process.executor = 'pbspro'
        process.queue    = 'workq'
        process.time     = '72h'
        process.memory   = '32GB'
        process.cpus     = 8
    }
}

process {
    conda = '/home/habee/miniconda3/envs/metagenome'

    withLabel: 'fastqc'    { cpus = 4;  memory = 8.GB;  time = 4.h  }
    withLabel: 'fastp'     { cpus = 4;  memory = 8.GB;  time = 8.h  }
    withLabel: 'megahit'   { cpus = 8;  memory = 10.GB; time = 72.h }
    withLabel: 'metabat2'  { cpus = 4;  memory = 6.GB;  time = 24.h }
    withLabel: 'concoct'   { cpus = 8;  memory = 10.GB; time = 24.h }
    withLabel: 'maxbin2'   { cpus = 4;  memory = 6.GB;  time = 24.h }
    withLabel: 'dastool'   { cpus = 8;  memory = 10.GB; time = 24.h }
    withLabel: 'quast'     { cpus = 8;  memory = 10.GB; time = 24.h }
    withLabel: 'checkm'    { cpus = 8;  memory = 10.GB; time = 48.h }
    withLabel: 'gtdbtk'    { cpus = 8;  memory = 14.GB; time = 72.h }
    withLabel: 'kraken2'   { cpus = 8;  memory = 10.GB; time = 48.h }
    withLabel: 'humann'    { cpus = 8;  memory = 12.GB; time = 48.h }
    withLabel: 'krona'     { cpus = 2;  memory = 4.GB;  time = 2.h  }
    withLabel: 'eggnog'    { cpus = 4;  memory = 8.GB;  time = 24.h }
    withLabel: 'diversity' { cpus = 2;  memory = 4.GB;  time = 4.h  }
    withLabel: 'diffabund' { cpus = 4;  memory = 8.GB;  time = 8.h  }
    withLabel: 'multiqc'   { cpus = 2;  memory = 4.GB;  time = 2.h  }
}

docker.enabled = true

manifest {
    name        = 'metagenome-pipeline'
    author      = 'Metagenome Team'
    version     = '2.0.0'
    description = 'Illumina shotgun metagenomics analysis pipeline'
    mainScript  = 'main.nf'
}
